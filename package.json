{
  "name": "airwave-prototype",
  "version": "1.0.0",
  "description": "Airwave app UI/UX prototyping tool",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "dev:electron": "ELECTRON=true vite",
    "build:web": "vite build",
    "build:electron": "ELECTRON=true vite build",
    "build": "ELECTRON=true vite build && electron-builder --mac --config",
    "preview": "vite preview"
  },
  "dependencies": {
    "@tensorflow-models/blazeface": "^0.1.0",
    "@tensorflow/tfjs": "^4.22.0",
    "html-to-image": "^1.11.13",
    "jszip": "^3.10.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0"
  },
  "build": {
    "appId": "com.wavelengthlabs.airwave-prototype",
    "productName": "Airwave Prototype",
    "mac": {
      "target": [
        "dmg",
        "dir"
      ],
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "asarUnpack": [
      "dist/media/**/*",
      "dist/images/**/*",
      "dist/icons/**/*",
      "dist/avatars/**/*"
    ]
  }
}
